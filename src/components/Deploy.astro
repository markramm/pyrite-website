---
---

<section id="deploy" class="px-6 py-20 max-w-4xl mx-auto">
  <h2 class="text-3xl font-bold text-center mb-4">Deploy your own</h2>
  <p class="text-text-secondary text-center mb-10 max-w-2xl mx-auto">
    Notion Team: $10/user/month. Pyrite on a $6 VPS: unlimited users, you own
    your data.
  </p>

  <div class="bg-surface-raised rounded-xl border border-white/5 p-6">
    <div class="font-mono text-sm space-y-1">
      <p class="text-text-muted"># Clone and deploy (Ubuntu VPS with Docker)</p>
      <p>
        <span class="text-pyrite-400">$</span> git clone
        https://github.com/markramm/pyrite && cd pyrite
      </p>
      <p>
        <span class="text-pyrite-400">$</span> bash deploy/selfhost/setup.sh
        kb.example.com
      </p>
      <p></p>
      <p class="text-text-muted"># Create your admin user</p>
      <p>
        <span class="text-pyrite-400">$</span> docker compose -f
        deploy/selfhost/docker-compose.yml exec pyrite \
      </p>
      <p class="pl-6">
        python /app/deploy/selfhost/create-user.py admin yourpassword
      </p>
    </div>
  </div>

  <div class="grid sm:grid-cols-3 gap-6 mt-10 text-center">
    <div>
      <div class="text-2xl font-bold text-pyrite-400">~2 min</div>
      <div class="text-text-secondary text-sm">Clone to running instance</div>
    </div>
    <div>
      <div class="text-2xl font-bold text-pyrite-400">$6/mo</div>
      <div class="text-text-secondary text-sm">Hetzner CX22, unlimited users</div>
    </div>
    <div>
      <div class="text-2xl font-bold text-pyrite-400">Auto TLS</div>
      <div class="text-text-secondary text-sm">Caddy provisions certificates</div>
    </div>
  </div>
</section>
