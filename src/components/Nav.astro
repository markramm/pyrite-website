---
---

<nav class="border-b border-white/10 px-6 py-4">
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <a href="/" class="text-xl font-bold">
      <span class="text-gradient">Py</span>rite
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-6 text-sm text-text-secondary">
      <a href="/use-cases" class="hover:text-text-primary transition-colors"
        >Use Cases</a
      >
      <a href="/plugins" class="hover:text-text-primary transition-colors"
        >Plugins</a
      >
      <a href="/docs" class="hover:text-text-primary transition-colors">Docs</a
      >
      <a
        href="https://demo.pyrite.wiki"
        class="hover:text-text-primary transition-colors">Demo</a
      >
      <a
        href="https://github.com/markramm/pyrite"
        class="hover:text-text-primary transition-colors">GitHub</a
      >
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="sm:hidden p-2 text-text-secondary hover:text-text-primary"
      aria-label="Open menu"
    >
      <svg
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden sm:hidden mt-4 pb-2 flex flex-col gap-3 text-sm text-text-secondary"
  >
    <a href="/use-cases" class="hover:text-text-primary transition-colors"
      >Use Cases</a
    >
    <a href="/plugins" class="hover:text-text-primary transition-colors"
      >Plugins</a
    >
    <a href="/docs" class="hover:text-text-primary transition-colors">Docs</a>
    <a
      href="https://demo.pyrite.wiki"
      class="hover:text-text-primary transition-colors">Demo</a
    >
    <a
      href="https://github.com/markramm/pyrite"
      class="hover:text-text-primary transition-colors">GitHub</a
    >
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
