---
import "../assets/styles.css";
import Nav from "../components/Nav.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const { title, description = "Pyrite documentation", currentSlug } = Astro.props;

function slugify(id: string) {
  return id.replace(/\.md$/, "");
}

const allDocs = await getCollection("docs");
const sorted = allDocs.sort((a, b) => a.data.order - b.data.order);

const sections = [
  { key: "get-started", label: "Get Started" },
  { key: "concepts", label: "Core Concepts" },
  { key: "reference", label: "Reference" },
  { key: "build", label: "Build & Extend" },
] as const;
---

<!doctype html>
<html lang="en" class="bg-surface text-text-primary">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Nav />

    <div class="flex-1 flex max-w-7xl mx-auto w-full">
      <!-- Sidebar -->
      <aside class="hidden lg:block w-64 shrink-0 border-r border-white/10 py-8 pr-6 pl-6 overflow-y-auto sticky top-0 h-screen">
        <nav class="space-y-6">
          {sections.map(({ key, label }) => {
            const sectionDocs = sorted.filter((d) => d.data.section === key);
            return sectionDocs.length > 0 ? (
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-2">
                  {label}
                </h3>
                <ul class="space-y-1">
                  {sectionDocs.map((doc) => {
                    const isActive = doc.id === currentSlug;
                    return (
                      <li>
                        <a
                          href={`/docs/${slugify(doc.id)}`}
                          class:list={[
                            "block px-3 py-1.5 rounded-md text-sm transition-colors",
                            isActive
                              ? "bg-pyrite-500/15 text-pyrite-400 font-medium"
                              : "text-text-secondary hover:text-text-primary hover:bg-white/5",
                          ]}
                        >
                          {doc.data.title}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ) : null;
          })}
        </nav>
      </aside>

      <!-- Mobile sidebar toggle + dropdown -->
      <div class="lg:hidden fixed bottom-4 right-4 z-50">
        <button
          id="docs-sidebar-btn"
          class="bg-pyrite-500 text-surface p-3 rounded-full shadow-lg hover:bg-pyrite-400 transition-colors"
          aria-label="Open docs navigation"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile sidebar overlay -->
      <div id="docs-sidebar-overlay" class="hidden lg:hidden fixed inset-0 z-40">
        <div class="absolute inset-0 bg-black/60" id="docs-sidebar-backdrop"></div>
        <aside class="absolute right-0 top-0 bottom-0 w-72 bg-surface border-l border-white/10 py-6 px-6 overflow-y-auto">
          <div class="flex justify-between items-center mb-6">
            <span class="text-sm font-semibold text-text-muted uppercase tracking-wider">Docs</span>
            <button id="docs-sidebar-close" class="text-text-muted hover:text-text-primary">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <nav class="space-y-6">
            {sections.map(({ key, label }) => {
              const sectionDocs = sorted.filter((d) => d.data.section === key);
              return sectionDocs.length > 0 ? (
                <div>
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-2">
                    {label}
                  </h3>
                  <ul class="space-y-1">
                    {sectionDocs.map((doc) => {
                      const isActive = doc.id === currentSlug;
                      return (
                        <li>
                          <a
                            href={`/docs/${slugify(doc.id)}`}
                            class:list={[
                              "block px-3 py-1.5 rounded-md text-sm transition-colors",
                              isActive
                                ? "bg-pyrite-500/15 text-pyrite-400 font-medium"
                                : "text-text-secondary hover:text-text-primary hover:bg-white/5",
                            ]}
                          >
                            {doc.data.title}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ) : null;
            })}
          </nav>
        </aside>
      </div>

      <!-- Content area -->
      <main class="flex-1 min-w-0 px-6 lg:px-12 py-8">
        <slot />
      </main>
    </div>

    <footer class="border-t border-white/10 px-6 py-8 text-center text-sm text-text-muted">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
        <p>MIT License. Built with Pyrite's own knowledge base.</p>
        <div class="flex gap-6">
          <a href="https://github.com/markramm/pyrite" class="hover:text-text-secondary transition-colors">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById("docs-sidebar-btn");
      const overlay = document.getElementById("docs-sidebar-overlay");
      const backdrop = document.getElementById("docs-sidebar-backdrop");
      const closeBtn = document.getElementById("docs-sidebar-close");

      function openSidebar() {
        overlay?.classList.remove("hidden");
      }
      function closeSidebar() {
        overlay?.classList.add("hidden");
      }

      btn?.addEventListener("click", openSidebar);
      backdrop?.addEventListener("click", closeSidebar);
      closeBtn?.addEventListener("click", closeSidebar);
    </script>
  </body>
</html>
